# Frontend (Vercel/Netlify/static build)
VITE_SUPABASE_URL=https://wrkqwkxdmqptrhuxjzcx.supabase.co
VITE_SUPABASE_ANON_KEY=cole_a_anon_key_do_supabase
# Deixe vazio quando frontend e API rodam no mesmo dominio, como na Hostinger Node.js App.
VITE_API_BASE_URL=

# Backend/API
PORT=3333
NODE_ENV=production
SUPABASE_URL=https://wrkqwkxdmqptrhuxjzcx.supabase.co
SUPABASE_ANON_KEY=cole_a_anon_key_do_supabase
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_do_supabase
CORS_ORIGIN=https://agendasport.com.br,https://www.agendasport.com.br
PUBLIC_API_URL=https://agendasport.com.br

# WhatsApp Meta Cloud API
WHATSAPP_PROVIDER=meta
WHATSAPP_ACCESS_TOKEN=cole_o_token_permanente_da_meta
WHATSAPP_PHONE_NUMBER_ID=cole_o_phone_number_id
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_VERIFY_TOKEN=agendasport_webhook_2026
WHATSAPP_CONFIRMATION_TEMPLATE_NAME=confirmacao_pelada
WHATSAPP_BILLING_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=pt_BR

# Workers
REMINDER_WORKER_ENABLED=true
REMINDER_INTERVAL_MINUTES=15
BILLING_WORKER_ENABLED=true
BILLING_INTERVAL_MINUTES=60

# Pagamentos. Ative inicialmente apenas o provedor escolhido.
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com/v3
# Segredo proprio de 32+ caracteres. Use o mesmo valor no webhook do Asaas.
ASAAS_WEBHOOK_TOKEN=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_API_URL=https://api.mercadopago.com
# Assinatura secreta fornecida pelo Mercado Pago ao cadastrar o webhook.
MERCADO_PAGO_WEBHOOK_SECRET=
